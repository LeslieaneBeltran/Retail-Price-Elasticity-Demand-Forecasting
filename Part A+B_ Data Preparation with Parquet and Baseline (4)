{"cells":[{"cell_type":"markdown","id":"a908de4e-30ed-4b1d-bb54-26d9a75a2920","metadata":{"id":"a908de4e-30ed-4b1d-bb54-26d9a75a2920"},"source":["Dataset: group2_m5_full_feature_dataset_v1.parquet\n","\n","Rows: ~20M\n","Coverage:\n","- Categories: FOODS, HOBBIES, HOUSEHOLD\n","- Stores: All 10 stores across CA, TX, WI\n","\n","Description:\n","This dataset contains fully preprocessed features for demand forecasting, price elasticity estimation, and ML modeling.\n","\n","Key Features:\n","- lag_7, lag_28: historical demand\n","- rolling_mean_7, rolling_mean_28: baseline demand\n","- log_sales: log-transformed demand\n","- log_price: log-transformed price\n","- log_price_diff_7: stable price-change feature\n","- price_change_pct: clipped weekly price change\n","- snap_flag: SNAP indicator\n","- event_flag + event type flags: promotional signals\n","\n","Important Notes:\n","- Dataset is NOT split into train/test\n","- Use time-based split only (do not use random split)\n","- item_id is high-cardinality and should be handled carefully in ML models"]},{"cell_type":"code","source":["from google.colab import drive\n","drive.mount('/content/drive')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"HcYbwNum08Kl","executionInfo":{"status":"ok","timestamp":1776810236493,"user_tz":300,"elapsed":12524,"user":{"displayName":"Panav Ladha","userId":"05161850510770886297"}},"outputId":"b98369c9-f104-4e02-b2fd-f8db89b4db39"},"id":"HcYbwNum08Kl","execution_count":2,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n"]}]},{"cell_type":"code","execution_count":3,"id":"1eeed612-5660-4b06-8868-c97955c7d75c","metadata":{"id":"1eeed612-5660-4b06-8868-c97955c7d75c","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776810240015,"user_tz":300,"elapsed":1623,"user":{"displayName":"Panav Ladha","userId":"05161850510770886297"}},"outputId":"63f4d9ce-1b92-460b-93af-a9733cfa9e50"},"outputs":[{"output_type":"stream","name":"stdout","text":["['sales_train_evaluation.csv', 'calendar.csv', 'sample_submission.csv', 'sales_train_validation.csv', 'sell_prices.csv']\n"]}],"source":["# =========================================================\n","# Cell 1\n","# Imports, notebook settings, and helper functions\n","# =========================================================\n","\n","import os\n","import gc\n","import numpy as np\n","import pandas as pd\n","\n","pd.set_option(\"display.max_columns\", 200)\n","\n","# Set your working directory if needed\n","DATA_DIR = \"/content/drive/MyDrive/Advance Machine Learning Project - Team 2/Source Data\"\n","print(os.listdir(DATA_DIR))\n","#DATA_DIR = \".\"\n","\n","def mem_gb(df):\n","    \"\"\"\n","    Return approximate DataFrame memory usage in GB.\n","    \"\"\"\n","    return round(df.memory_usage(deep=True).sum() / 1024**3, 3)\n","\n","def optimize_dtypes(df):\n","    \"\"\"\n","    Reduce memory usage by:\n","    1) downcasting numeric columns\n","    2) converting repeated string columns to category dtype\n","    \"\"\"\n","    # Downcast integers\n","    int_cols = df.select_dtypes(include=[\"int64\", \"int32\"]).columns\n","    for col in int_cols:\n","        df[col] = pd.to_numeric(df[col], downcast=\"integer\")\n","\n","    # Downcast floats\n","    float_cols = df.select_dtypes(include=[\"float64\"]).columns\n","    for col in float_cols:\n","        df[col] = pd.to_numeric(df[col], downcast=\"float\")\n","\n","    # Convert repeated object columns to category\n","    cat_candidates = [\n","        \"id\", \"item_id\", \"dept_id\", \"cat_id\", \"store_id\", \"state_id\",\n","        \"d\", \"weekday\", \"event_name_1\", \"event_type_1\",\n","        \"event_name_2\", \"event_type_2\", \"season\"\n","    ]\n","    for col in cat_candidates:\n","        if col in df.columns and df[col].dtype == \"object\":\n","            df[col] = df[col].astype(\"category\")\n","\n","    return df"]},{"cell_type":"code","execution_count":4,"id":"b7c4f74f-8b6c-4f93-add8-28f0970dec11","metadata":{"id":"b7c4f74f-8b6c-4f93-add8-28f0970dec11","outputId":"af1caf1b-a9c7-47d6-c492-64ce9a5c8cdf","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776810255891,"user_tz":300,"elapsed":13528,"user":{"displayName":"Panav Ladha","userId":"05161850510770886297"}}},"outputs":[{"output_type":"stream","name":"stdout","text":["calendar: (1969, 14)\n","prices: (6841121, 4)\n","sales: (30490, 1919)\n","sales memory (GB): 0.445\n","calendar after filter: (676, 14)\n","2014-06-19 00:00:00 to 2016-04-24 00:00:00\n","sales after filter: (30490, 682)\n","number of d columns kept: 676\n"]}],"source":["# =========================================================\n","# Cell 2\n","# Load raw source files\n","# =========================================================\n","\n","calendar = pd.read_csv(\n","    os.path.join(DATA_DIR, \"calendar.csv\"),\n","    parse_dates=[\"date\"]\n",")\n","\n","prices = pd.read_csv(\n","    os.path.join(DATA_DIR, \"sell_prices.csv\")\n",")\n","\n","sales = pd.read_csv(\n","    os.path.join(DATA_DIR, \"sales_train_validation.csv\")\n",")\n","\n","print(\"calendar:\", calendar.shape)\n","print(\"prices:\", prices.shape)\n","print(\"sales:\", sales.shape)\n","print(\"sales memory (GB):\", mem_gb(sales))\n","\n","# 1. Trim calendar to match validation data range\n","start_date = \"2014-06-19\"\n","end_date = \"2016-04-24\"   # last date available in sales_train_validation.csv\n","\n","calendar = calendar[\n","    (calendar[\"date\"] >= start_date) &\n","    (calendar[\"date\"] <= end_date)\n","].copy()\n","\n","print(\"calendar after filter:\", calendar.shape)\n","print(calendar[\"date\"].min(), \"to\", calendar[\"date\"].max())\n","\n","# 2. Keep only relevant 'd' columns in sales\n","id_cols = [\"id\", \"item_id\", \"dept_id\", \"cat_id\", \"store_id\", \"state_id\"]\n","valid_d = [d for d in calendar[\"d\"].tolist() if d in sales.columns]\n","\n","sales = sales[id_cols + valid_d].copy()\n","\n","print(\"sales after filter:\", sales.shape)\n","print(\"number of d columns kept:\", len(valid_d))"]},{"cell_type":"code","execution_count":5,"id":"48969ba0-43ed-4ff2-b15a-f687cac7b42d","metadata":{"id":"48969ba0-43ed-4ff2-b15a-f687cac7b42d","outputId":"b557a17a-a527-4078-f738-0b77fd085298","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776810286294,"user_tz":300,"elapsed":27585,"user":{"displayName":"Panav Ladha","userId":"05161850510770886297"}}},"outputs":[{"output_type":"stream","name":"stdout","text":["sales_long shape: (20611240, 8)\n","sales_long memory (GB): 0.234\n"]},{"output_type":"execute_result","data":{"text/plain":["0"]},"metadata":{},"execution_count":5}],"source":["# =========================================================\n","# Cell 3\n","# Convert wide sales data into long format\n","# =========================================================\n","\n","# Use the full dataset: all categories and all stores\n","#sales_full = sales. #.copy(). #*****GETTING RID OF COPY AND SALES_FULL\n","\n","id_cols = [\"id\", \"item_id\", \"dept_id\", \"cat_id\", \"store_id\", \"state_id\"]\n","day_cols = [c for c in sales.columns if c.startswith(\"d_\")] #day_cols = [c for c in sales_full.columns if c.startswith(\"d_\")]\n","\n","sales_long = sales.melt(   #sales_long = sales_full.melt(\n","    id_vars=id_cols,\n","    value_vars=day_cols,\n","    var_name=\"d\",\n","    value_name=\"sales\"\n",")\n","\n","sales_long = optimize_dtypes(sales_long)\n","\n","print(\"sales_long shape:\", sales_long.shape)\n","print(\"sales_long memory (GB):\", mem_gb(sales_long))\n","\n","del sales #sales_full\n","gc.collect()"]},{"cell_type":"code","execution_count":6,"id":"c4fb8002-b96e-4668-9bea-e23ca81f47ad","metadata":{"id":"c4fb8002-b96e-4668-9bea-e23ca81f47ad","outputId":"b824f9f7-cb87-452d-85bf-279fe5035845","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776810343017,"user_tz":300,"elapsed":50756,"user":{"displayName":"Panav Ladha","userId":"05161850510770886297"}}},"outputs":[{"output_type":"stream","name":"stdout","text":["after calendar merge: (20611240, 20) mem(GB): 0.637\n","after prices merge: (20611240, 21) mem(GB): 2.935\n","missing sell_price ratio: 0.018855100420935373\n","after dropping missing prices: (20222613, 21) mem(GB): 3.031\n"]},{"output_type":"execute_result","data":{"text/plain":["0"]},"metadata":{},"execution_count":6}],"source":["# =========================================================\n","# Cell 4\n","# Merge calendar and weekly price data\n","# =========================================================\n","\n","calendar_keep = calendar[\n","    [\n","        \"d\", \"date\", \"wm_yr_wk\", \"weekday\", \"month\", \"year\",\n","        \"event_name_1\", \"event_type_1\", \"event_name_2\", \"event_type_2\",\n","        \"snap_CA\", \"snap_TX\", \"snap_WI\"\n","    ]\n","].copy()\n","\n","calendar_keep = optimize_dtypes(calendar_keep)\n","\n","# Merge calendar\n","df = sales_long.merge(\n","    calendar_keep,\n","    on=\"d\",\n","    how=\"left\",\n","    validate=\"many_to_one\"\n",")\n","\n","print(\"after calendar merge:\", df.shape, \"mem(GB):\", mem_gb(df))\n","\n","del sales_long, calendar_keep\n","gc.collect()\n","\n","# Merge prices using store_id + item_id + wm_yr_wk\n","df = df.merge(\n","    prices,\n","    on=[\"store_id\", \"item_id\", \"wm_yr_wk\"],\n","    how=\"left\",\n","    validate=\"many_to_one\"\n",")\n","\n","print(\"after prices merge:\", df.shape, \"mem(GB):\", mem_gb(df))\n","print(\"missing sell_price ratio:\", df[\"sell_price\"].isna().mean())\n","\n","# Drop rows without price\n","df = df[df[\"sell_price\"].notna()].copy()\n","\n","print(\"after dropping missing prices:\", df.shape, \"mem(GB):\", mem_gb(df))\n","\n","del prices\n","gc.collect()"]},{"cell_type":"code","execution_count":7,"id":"7b123d43-e654-4262-b2fe-8104b0daad4e","metadata":{"id":"7b123d43-e654-4262-b2fe-8104b0daad4e","executionInfo":{"status":"ok","timestamp":1776810361459,"user_tz":300,"elapsed":15252,"user":{"displayName":"Panav Ladha","userId":"05161850510770886297"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"4186dbce-74ef-4815-b9b8-2949241733af"},"outputs":[{"output_type":"stream","name":"stdout","text":["(20222613, 34) mem(GB): 1.115\n"]}],"source":["# =========================================================\n","# Cell 5\n","# Create calendar-based, SNAP, and event features\n","# =========================================================\n","\n","df[\"date\"] = pd.to_datetime(df[\"date\"])\n","\n","# Basic time features\n","df[\"day_of_month\"] = df[\"date\"].dt.day.astype(\"int8\")\n","df[\"week_of_year\"] = df[\"date\"].dt.isocalendar().week.astype(\"int16\")\n","df[\"quarter\"] = df[\"date\"].dt.quarter.astype(\"int8\")\n","df[\"is_month_start\"] = df[\"date\"].dt.is_month_start.astype(\"int8\")\n","df[\"is_month_end\"] = df[\"date\"].dt.is_month_end.astype(\"int8\")\n","df[\"is_weekend\"] = df[\"weekday\"].isin([\"Saturday\", \"Sunday\"]).astype(\"int8\")\n","\n","# Season feature\n","df[\"season\"] = np.select(\n","    [\n","        df[\"month\"].isin([12, 1, 2]),\n","        df[\"month\"].isin([3, 4, 5]),\n","        df[\"month\"].isin([6, 7, 8]),\n","        df[\"month\"].isin([9, 10, 11]),\n","    ],\n","    [\"winter\", \"spring\", \"summer\", \"fall\"],\n","    default=\"unknown\"\n",")\n","df[\"season\"] = df[\"season\"].astype(\"category\")\n","\n","# State-specific SNAP flag\n","df[\"snap_flag\"] = np.where(\n","    df[\"state_id\"].eq(\"CA\"), df[\"snap_CA\"],\n","    np.where(df[\"state_id\"].eq(\"TX\"), df[\"snap_TX\"], df[\"snap_WI\"])\n",").astype(\"int8\")\n","\n","# General event flag\n","df[\"event_flag\"] = (\n","    df[\"event_name_1\"].notna() |\n","    df[\"event_name_2\"].notna()\n",").astype(\"int8\")\n","\n","# Event-type-specific flags\n","for event_type in [\"Cultural\", \"National\", \"Religious\", \"Sporting\"]:\n","    colname = f\"event_{event_type.lower()}\"\n","    df[colname] = (\n","        (df[\"event_type_1\"] == event_type) |\n","        (df[\"event_type_2\"] == event_type)\n","    ).astype(\"int8\")\n","\n","df = optimize_dtypes(df)\n","\n","print(df.shape, \"mem(GB):\", mem_gb(df))"]},{"cell_type":"code","execution_count":8,"id":"b86bee34-f151-4fb1-aecc-bcd916017a35","metadata":{"id":"b86bee34-f151-4fb1-aecc-bcd916017a35","executionInfo":{"status":"ok","timestamp":1776810413070,"user_tz":300,"elapsed":48591,"user":{"displayName":"Panav Ladha","userId":"05161850510770886297"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"05411f68-0b43-4e99-bf1d-54ac9fe81d70"},"outputs":[{"output_type":"stream","name":"stdout","text":["        item_id store_id       date  sales  lag_7  lag_28  rolling_mean_7  \\\n","0   FOODS_1_001     CA_1 2014-06-19      0    NaN     NaN             NaN   \n","1   FOODS_1_001     CA_1 2014-06-20      1    NaN     NaN             NaN   \n","2   FOODS_1_001     CA_1 2014-06-21      0    NaN     NaN             NaN   \n","3   FOODS_1_001     CA_1 2014-06-22      1    NaN     NaN             NaN   \n","4   FOODS_1_001     CA_1 2014-06-23      2    NaN     NaN             NaN   \n","5   FOODS_1_001     CA_1 2014-06-24      0    NaN     NaN             NaN   \n","6   FOODS_1_001     CA_1 2014-06-25      1    NaN     NaN             NaN   \n","7   FOODS_1_001     CA_1 2014-06-26      1    0.0     NaN        0.714286   \n","8   FOODS_1_001     CA_1 2014-06-27      2    1.0     NaN        0.857143   \n","9   FOODS_1_001     CA_1 2014-06-28      1    0.0     NaN        1.000000   \n","10  FOODS_1_001     CA_1 2014-06-29      0    1.0     NaN        1.142857   \n","11  FOODS_1_001     CA_1 2014-06-30      1    2.0     NaN        1.000000   \n","12  FOODS_1_001     CA_1 2014-07-01      0    0.0     NaN        0.857143   \n","13  FOODS_1_001     CA_1 2014-07-02      0    1.0     NaN        0.857143   \n","14  FOODS_1_001     CA_1 2014-07-03      0    1.0     NaN        0.714286   \n","\n","    rolling_mean_28  \n","0               NaN  \n","1               NaN  \n","2               NaN  \n","3               NaN  \n","4               NaN  \n","5               NaN  \n","6               NaN  \n","7               NaN  \n","8               NaN  \n","9               NaN  \n","10              NaN  \n","11              NaN  \n","12              NaN  \n","13              NaN  \n","14              NaN  \n","(20222613, 38) mem(GB): 1.265\n"]}],"source":["# =========================================================\n","# Cell 6\n","# Create lag and rolling features\n","# =========================================================\n","\n","# Sort before time-series feature engineering\n","df = df.sort_values([\"item_id\", \"store_id\", \"date\"]).reset_index(drop=True)\n","\n","group_cols = [\"item_id\", \"store_id\"]\n","\n","# Lag features\n","df[\"lag_7\"] = df.groupby(group_cols, observed=True)[\"sales\"].shift(7)\n","df[\"lag_28\"] = df.groupby(group_cols, observed=True)[\"sales\"].shift(28)\n","\n","# Leakage-safe rolling means\n","df[\"rolling_mean_7\"] = (\n","    df.groupby(group_cols, observed=True)[\"sales\"]\n","      .transform(lambda x: x.shift(1).rolling(7).mean())\n",")\n","\n","df[\"rolling_mean_28\"] = (\n","    df.groupby(group_cols, observed=True)[\"sales\"]\n","      .transform(lambda x: x.shift(1).rolling(28).mean())\n",")\n","\n","df = optimize_dtypes(df)\n","\n","print(df[[\n","    \"item_id\", \"store_id\", \"date\", \"sales\",\n","    \"lag_7\", \"lag_28\", \"rolling_mean_7\", \"rolling_mean_28\"\n","]].head(15))\n","\n","print(df.shape, \"mem(GB):\", mem_gb(df))"]},{"cell_type":"code","execution_count":9,"id":"d6236236-d0b8-470f-bbe8-d989b71f1705","metadata":{"id":"d6236236-d0b8-470f-bbe8-d989b71f1705","executionInfo":{"status":"ok","timestamp":1776810428666,"user_tz":300,"elapsed":11735,"user":{"displayName":"Panav Ladha","userId":"05161850510770886297"}},"colab":{"base_uri":"https:/