,"metadata":{"id":"MmQbicBeP_XO"},"id":"MmQbicBeP_XO"},{"cell_type":"code","source":["from sklearn.metrics import mean_squared_error, mean_absolute_error, r2_score\n","import numpy as np\n","\n","# Predict in log space\n","y_pred_log = model.predict(X_test_reg)\n","\n","# Convert back to original sales scale\n","## y_pred = np.exp(y_pred_log)\n","\n","# Clip log predictions before exponentiating to prevent explosion\n","# log(50000) ≈ 10.8, so anything above ~12 is likely a runaway prediction\n","y_pred_log_clipped = np.clip(y_pred_log, a_min=None, a_max=12)\n","y_pred = np.exp(y_pred_log_clipped)\n","\n","# Actual values must match test_reg, not test\n","y_true = test[\"sales\"]\n","\n","# Sanity check: metrics in log-space (apples-to-apples with OLS output)\n","rmse_log = np.sqrt(mean_squared_error(y_test_reg, y_pred_log))\n","mae_log  = mean_absolute_error(y_test_reg, y_pred_log)\n","r2_log   = r2_score(y_test_reg, y_pred_log)\n","print(f\"\\n=== Log-Space Check (expected R²≈0.40) ===\")\n","print(f\"RMSE: {rmse_log:.4f} | MAE: {mae_log:.4f} | R²: {r2_log:.4f}\")\n","\n","# Metrics\n","rmse_reg = np.sqrt(mean_squared_error(y_true, y_pred))\n","mae_reg = mean_absolute_error(y_true, y_pred)\n","r2_reg = r2_score(y_true, y_pred)\n","\n","print(\"\\n=== Log-Log Regression ===\")\n","print(\"RMSE:\", rmse_reg)\n","print(\"MAE :\", mae_reg)\n","print(\"R²  :\", r2_reg)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"O2BZ_uWxQBoj","executionInfo":{"status":"ok","timestamp":1776810560110,"user_tz":300,"elapsed":329,"user":{"displayName":"Panav Ladha","userId":"05161850510770886297"}},"outputId":"5c25d476-45e8-4d08-a749-650f3b4a15d7"},"id":"O2BZ_uWxQBoj","execution_count":20,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== Log-Space Check (expected R²≈0.40) ===\n","RMSE: 0.5721 | MAE: 0.4542 | R²: 0.5054\n","\n","=== Log-Log Regression ===\n","RMSE: 3.418602159538927\n","MAE : 1.4879302993177579\n","R²  : 0.5266996313801079\n"]}]},{"